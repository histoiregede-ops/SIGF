NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sigef
DB_USER=root
DB_PASSWORD=password
DB_DIALECT=mysql

# JWT - CRITICAL: Copy to .env, generate strong 32-64 char secret (e.g. openssl rand -base64 48)
JWT_SECRET=your-super-secure-random-jwt-secret-key-change-this-in-prod-min-32-chars!!

# Mail (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# Others...
SKIP_MIGRATIONS=false

